{
  "name": "tooning",
  "displayName": "Tooning: AI Codebase Chat",
  "description": "Convert natural language queries to TOON by indexing your entire codebase.",
  "version": "11.0.1",
  "publisher": "OmkarPalika",
  "license": "MIT",
  "icon": "icon.png",
  "files": [
    "dist",
    "src/ui/webview",
    "icon.png",
    "LICENSE",
    "CHANGELOG.md",
    "README.md"
  ],
  "bin": {
    "toon": "./dist/bin/toon.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OmkarPalika/tooning.git"
  },
  "engines": {
    "vscode": "^1.116.0",
    "node": ">=22.0.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "chat",
    "codebase",
    "indexing",
    "semantic",
    "reranking",
    "toon"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./extension": "./dist/extension.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tooning-explorer",
          "title": "Tooning",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "tooning-explorer": [
        {
          "icon": "$(chat-read)",
          "type": "webview",
          "id": "tooning.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "tooning.reindexWorkspace",
        "title": "Tooning: Re-index Workspace",
        "icon": "$(sync)"
      },
      {
        "command": "tooning.clearHistory",
        "title": "Tooning: Clear Chat History",
        "icon": "$(trash)"
      },
      {
        "command": "tooning.analyzeSelection",
        "title": "Tooning: Analyze Selection"
      },
      {
        "command": "tooning.openSettings",
        "title": "Tooning: Settings",
        "icon": "$(settings-gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tooning.reindexWorkspace",
          "when": "view == tooning.chatView",
          "group": "navigation"
        },
        {
          "command": "tooning.clearHistory",
          "when": "view == tooning.chatView",
          "group": "navigation"
        },
        {
          "command": "tooning.openSettings",
          "group": "navigation",
          "when": "view == tooning.chatView"
        }
      ],
      "editor/context": [
        {
          "command": "tooning.analyzeSelection",
          "group": "modification",
          "when": "editorHasSelection"
        }
      ]
    },
    "configuration": {
      "title": "Tooning",
      "properties": {
        "tooning.provider": {
          "type": "string",
          "enum": [
            "mistral",
            "openai",
            "anthropic",
            "openrouter",
            "ollama"
          ],
          "default": "mistral",
          "description": "AI provider to use for Tooning."
        },
        "tooning.apiKey": {
          "type": "string",
          "default": "",
          "description": "API Key for the selected provider (Leave blank for Ollama)."
        },
        "tooning.model": {
          "type": "string",
          "default": "mistral-large-latest",
          "description": "Model ID to use."
        },
        "tooning.customBaseUrl": {
          "type": "string",
          "default": "http://localhost:11434/api/chat",
          "description": "Custom Base URL (e.g. for Ollama or OpenRouter)."
        },
        "tooning.indexMode": {
          "type": "string",
          "enum": [
            "realtime",
            "interval",
            "onSave",
            "manual"
          ],
          "default": "realtime",
          "description": "When to update the codebase index. 'realtime' uses a background viewer for instant updates."
        },
        "tooning.indexInterval": {
          "type": "number",
          "default": 15,
          "description": "Interval in minutes if indexMode is 'interval'."
        },
        "tooning.maxFileSizeKB": {
          "type": "number",
          "default": 500,
          "description": "Skip files larger than this size (KB)."
        },
        "tooning.maxContextTokens": {
          "type": "number",
          "default": 16000,
          "description": "Maximum tokens to send in the prompt."
        },
        "tooning.showRawToon": {
          "type": "boolean",
          "default": true,
          "description": "Show the raw TOON response in chat."
        },
        "tooning.security.allowSensitiveFiles": {
          "type": "boolean",
          "default": false,
          "description": "If enabled, Tooning will ignore sensitive patterns (.env, keys) and include them."
        },
        "tooning.security.allowOutsideWorkspace": {
          "type": "boolean",
          "default": false,
          "description": "If enabled, allows access to files outside of your workspace folders."
        },
        "tooning.security.sensitivePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.env*",
            "**/*.pem",
            "**/*.key",
            "**/id_rsa*",
            "**/shadow",
            "**/passwd"
          ],
          "description": "Glob patterns to identify sensitive files to be blocked."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/ui": "^4.1.4",
    "eslint": "^8.57.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "js-tiktoken": "^1.0.21",
    "p-limit": "^7.3.0",
    "pdf-parse": "^2.4.5",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz"
  }
}
